<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:id="@+id/main">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText android:id="@+id/et_name" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Nume produs" />
            <EditText android:id="@+id/et_price" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Pret" android:inputType="numberDecimal" />
            <EditText android:id="@+id/et_quantity" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Cantitate" android:inputType="number" />

            <Button android:id="@+id/btn_insert" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="1. Inserare" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@android:color/darker_gray" android:layout_marginVertical="8dp"/>

            <Button android:id="@+id/btn_get_all" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="2. Selectie Toate" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <EditText android:id="@+id/et_search_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Nume de cautat" />
                <Button android:id="@+id/btn_get_by_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3. Cauta Nume" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <EditText android:id="@+id/et_min_q" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Min Q" android:inputType="number" />
                <EditText android:id="@+id/et_max_q" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Max Q" android:inputType="number" />
                <Button android:id="@+id/btn_get_range" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4. Interval Q" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <EditText android:id="@+id/et_price_threshold" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Prag Pret" android:inputType="numberDecimal" />
                <Button android:id="@+id/btn_delete_price" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5. Sterge > Pret" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <EditText android:id="@+id/et_prefix" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Litera/Prefix" />
                <Button android:id="@+id/btn_update_prefix" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="6. Increment Prefix" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <ListView
        android:id="@+id/lv_products"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
