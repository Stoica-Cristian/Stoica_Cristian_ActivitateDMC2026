<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/app_name"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRefreshDashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="Refresh"
                    android:textColor="@color/accent_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSettingsDashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="Setari"
                    android:textColor="@color/accent_primary"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardTopEvent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@color/surface"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Incident principal"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvRiskScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/risk_high"
                        android:textSize="52sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTopEvent"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressDashboard"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:indeterminate="true" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvDashboardSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@color/surface"
                android:elevation="1dp"
                android:lineSpacingExtra="5dp"
                android:padding="16dp"
                android:text="Se incarca statisticile..."
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <com.example.proiect.ui.DashboardPieChartView
                android:id="@+id/chartSeverityDashboard"
                android:layout_width="match_parent"
                android:layout_height="210dp"
                android:layout_marginTop="14dp"
                android:background="@color/surface"
                android:elevation="1dp"
                android:padding="4dp" />

            <com.example.proiect.ui.DashboardPieChartView
                android:id="@+id/chartConfidenceDashboard"
                android:layout_width="match_parent"
                android:layout_height="210dp"
                android:layout_marginTop="14dp"
                android:background="@color/surface"
                android:elevation="1dp"
                android:padding="4dp" />
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/view_bottom_navigation" />
</LinearLayout>
